        "return-type": "json"
    },
    "custom/pre": {
        "exec": "python3 ~/.config/waybar/scripts/pre.py --player spotify",
        "format": "{}",
        "tooltip": false,
        "on-click": "playerctl previous",
        "return-type": "json"
    },
    "custom/ibus": {
        "format": "{}",
